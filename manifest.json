{
  "manifest_version": 3,
  "name": "Unacademy PiP Fixer",
  "version": "1.2.0",
  "description": "Hides the Unacademy camera box and forces native Picture-in-Picture.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://*.uacdn.net/*",
    "*://*.unacademy.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Unacademy PiP Fixer",
    "default_icon": "icon48.png",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-pip": {
      "suggested_key": {
        "default": "Alt+C",
        "mac": "Command+Shift+C"
      },
      "description": "Activate Picture-in-Picture"
    },
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Open Color Picker Popup"
    }
  }
}