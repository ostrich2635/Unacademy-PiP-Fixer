{
  "manifest_version": 3,
  "name": "Unacademy PiP Fixer",
  "version": "1.0",
  "description": "Hides the Unacademy camera box and forces native Picture-in-Picture.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "*://*.uacdn.net/*",
    "*://*.unacademy.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Click to Pop Out Video",
    "default_icon": "icon48.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}